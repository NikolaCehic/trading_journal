# Required
DATABASE_URL=postgresql://user:pass@host/db
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_APP_URL=http://localhost:3000

# AI Narrator (Phase 4) - Anthropic required, Resend optional
# ANTHROPIC_API_KEY is now required for AI narrator features
ANTHROPIC_API_KEY=sk-ant-...
# RESEND_API_KEY is optional; if missing, email sends run in log-only mode
# RESEND_API_KEY=re_...
# DIGEST_FROM_EMAIL is only required when RESEND_API_KEY is set
# DIGEST_FROM_EMAIL=noreply@example.com
# AI_ENABLED controls the narrator kill switch
# AI_ENABLED=on

# Optional until later phases
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
SENTRY_DSN=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
